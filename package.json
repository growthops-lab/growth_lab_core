{
  "name": "growth-lab-affiliate-media-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "worker": "tsx src/workers/scheduler.ts",
    "worker:operations": "tsx src/workers/operations-worker.ts",
    "worker:social-post": "tsx src/workers/social-post-worker.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm worker\" \"pnpm worker:operations\" \"pnpm worker:social-post\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "worker:publish-due": "tsx scripts/publish-due.ts",
    "smoke:phase9": "tsx scripts/phase9-smoke.ts",
    "smoke:phase10": "tsx scripts/phase10-smoke.ts",
    "lint:openapi": "spectral lint -r implementation/lint_configs/openapi/approval_gate_openapi_spectral.yaml implementation/openapi/Approval_Gate_OpenAPI_Draft.yaml",
    "lint:openapi:version": "spectral --version"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^15.0.3",
    "node-cron": "^3.0.3",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@stoplight/spectral-cli": "^6.16.1",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prettier": "3.9.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "4.1.10",
    "yaml": "^2.9.0"
  }
}
