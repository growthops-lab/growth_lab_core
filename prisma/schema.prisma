model Campaign {
  id             String         @id @default(cuid())
  mediaId        String
  campaignName   String
  campaignCode   String         @unique
  campaignType   CampaignType
  status         CampaignStatus @default(PLANNING)
  periodStart    DateTime
  periodEnd      DateTime
  owner          String?
  description    String?
  primaryGoal    String?
  targetAudience String?
  currency       String         @default("JPY")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  objectives CampaignObjective[]
  targets CampaignTarget[]
  items CampaignItem[]
  budgets CampaignBudget[]
  costs CampaignCost[]
  revenueAttributions CampaignRevenueAttribution[]
  roiSnapshots CampaignRoiSnapshot[]
  growthScoreSnapshots CampaignGrowthScoreSnapshot[]
  recommendations CampaignRecommendation[]
  risks CampaignRisk[]
  milestones CampaignMilestone[]
  calendarEvents ContentCalendarEvent[]
  calendarConflicts ContentCalendarConflict[]
  reportSchedules ReportSchedule[]
  generatedReports GeneratedReport[]
  businessInsights BusinessInsight[]

  @@index([mediaId, status, periodStart])
  @@index([periodStart, periodEnd])
}

model CampaignObjective {
  id            String                  @id @default(cuid())
  campaignId    String
  objectiveType CampaignObjectiveType
  objectiveName String
  targetValue   Decimal                 @default(0) @db.Decimal(14, 2)
  currentValue  Decimal                 @default(0) @db.Decimal(14, 2)
  unit          String
